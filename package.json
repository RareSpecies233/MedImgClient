{
  "name": "medimg-client",
  "version": "1.0.0",
  "description": "Electron client with custom tabs, CLI process manager and settings",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^32.2.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.medimg.client",
    "productName": "MedImgClient",
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "renderer.js",
      "styles.css",
      "package.json",
      "bin/**/*"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    }
  }
}